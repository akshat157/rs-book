fn print_instructions() {
    println!("Use the following options to perform the desired operations.");
    println!("create <department name>\t: Create a new department with the given name.");
    println!(
        "delete <department name>\t: Delete a department with the given name.\nDeletes the list of employees in that department as well."
    );
    println!(
        "add <employee> from <department>\t: Add employee <employee> to department <department>."
    );
    println!(
        "remove <employee> from <department>\t: Add employee <employee> to department <department>."
    );

    println!(
        "show <department>\t: show the list of employees in department <department>, sorted alphabetically."
    );
    println!(
        "show all\t: show the all departments in the company with all employees, sorted alphabetically."
    );
}

